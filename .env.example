OPENAI_API_KEY=sk-your-key-here
TAVILY_API_KEY=tvly-your-key-here
BACKEND_URL=http://localhost:8000

# PostgreSQL — must match docker-compose db service (user/password/db)
POSTGRES_USER=chatbot
POSTGRES_PASSWORD=chatbot
POSTGRES_DB=chatbot
# App connection (localhost when backend runs on PC; use host "db" inside Docker)
DATABASE_URL=postgresql+psycopg2://chatbot:chatbot@localhost:5432/chatbot

# JWT — use a long random string in production
JWT_SECRET_KEY=change-me-to-a-long-random-secret
JWT_EXPIRE_MINUTES=1440

# Bootstrap admin (created on first startup if no admin exists)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=adminchange123
ADMIN_PHONE=
